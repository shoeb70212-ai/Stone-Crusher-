# ---------------------------------------------------------------------------
# CrushTrack ERP — Environment Variables
# ---------------------------------------------------------------------------

# DATABASE_URL: Supabase PostgreSQL connection string for Vercel deployment.
#
# ⚠️  You MUST use the "Transaction Pooler" connection string from Supabase.
#     Direct connections (port 5432, db.*.supabase.co) use IPv6 which Vercel
#     serverless functions do NOT support.
#
# How to get it:
#   1. Go to supabase.com/dashboard → Your project
#   2. Click "Connect" button at the top
#   3. Select "Transaction Pooler" tab
#   4. Copy the URI string
#
# Format:
#   postgres://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

DATABASE_URL="postgres://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres"

# ---------------------------------------------------------------------------
# Supabase Auth (browser-side — safe to expose, these are public keys)
# ---------------------------------------------------------------------------
# Get from: supabase.com/dashboard → Project → Settings → API

VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# ---------------------------------------------------------------------------
# Supabase Auth (server-side — NEVER expose to the browser)
#
# ⚠️  CRITICAL: This key bypasses Row Level Security.
#     - Only reference it in api/*.ts and scripts/*.ts (no VITE_ prefix).
#     - Never commit a real value to source control.
#     - Get it from: supabase.com/dashboard → Project → Settings → API
#       → "service_role" key (under "Project API keys")
# ---------------------------------------------------------------------------

SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# ---------------------------------------------------------------------------
# API Security
# ---------------------------------------------------------------------------

# VITE_API_URL: Base URL for API calls.
#
# Web (Vercel): Leave empty — Vite will use relative URLs (/api/data).
#
# Mobile APK build: Set to the Vercel deployment URL so the bundled APK
#   can reach the API from any network:
#     VITE_API_URL=https://stone-crusher.vercel.app
#   Then rebuild: npm run build && npx cap sync android

VITE_API_URL=""

# API_SECRET / VITE_API_KEY: Optional shared secret for /api/data endpoints.
# Leave empty for local dev. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

API_SECRET=""
VITE_API_KEY=""
