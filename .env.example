# ---------------------------------------------------------------------------
# CrushTrack ERP — Environment Variables
# ---------------------------------------------------------------------------

# DATABASE_URL: Supabase PostgreSQL connection string for Vercel deployment.
#
# ⚠️  You MUST use the "Transaction Pooler" connection string from Supabase.
#     Direct connections (port 5432, db.*.supabase.co) use IPv6 which Vercel
#     serverless functions do NOT support.
#
# How to get it:
#   1. Go to supabase.com/dashboard → Your project
#   2. Click "Connect" button at the top
#   3. Select "Transaction Pooler" tab
#   4. Copy the URI string
#
# Format:
#   postgres://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
#
# Note the differences from direct connection:
#   - Host: *.pooler.supabase.com (NOT db.*.supabase.co)
#   - Port: 6543 (NOT 5432)
#   - User: postgres.PROJECT_REF (NOT just postgres)

DATABASE_URL="postgres://postgres.oqhpjajzsmoiwfxhfifv:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres"

# GEMINI_API_KEY: Required for Gemini AI API calls (if used).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
