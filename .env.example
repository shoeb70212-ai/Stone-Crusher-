# ---------------------------------------------------------------------------
# CrushTrack ERP — Environment Variables
# ---------------------------------------------------------------------------

# DATABASE_URL: Supabase PostgreSQL connection string for Vercel deployment.
#
# ⚠️  You MUST use the "Transaction Pooler" connection string from Supabase.
#     Direct connections (port 5432, db.*.supabase.co) use IPv6 which Vercel
#     serverless functions do NOT support.
#
# How to get it:
#   1. Go to supabase.com/dashboard → Your project
#   2. Click "Connect" button at the top
#   3. Select "Transaction Pooler" tab
#   4. Copy the URI string
#
# Format:
#   postgres://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
#
# Note the differences from direct connection:
#   - Host: *.pooler.supabase.com (NOT db.*.supabase.co)
#   - Port: 6543 (NOT 5432)
#   - User: postgres.PROJECT_REF (NOT just postgres)

DATABASE_URL="postgres://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres"

# GEMINI_API_KEY: Required for Gemini AI API calls (if used).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# VITE_API_URL: Base URL for API calls.
#
# Web (Vercel): Leave empty — Vite will use relative URLs (/api/data) which
#   resolve correctly on the same domain.
#
# Mobile APK build: Set this to the Vercel deployment URL so the bundled
#   APK can reach the API from any network:
#     VITE_API_URL=https://stone-crusher.vercel.app
#   Then rebuild:  npm run build && npx cap sync android
#
VITE_API_URL=""

# API_SECRET / VITE_API_KEY: Shared secret for /api/data endpoints.
# Set the same value on both client and server. Leave empty for local dev.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET=""
VITE_API_KEY=""

# Supabase Auth — get from supabase.com/dashboard → Project → Settings → API
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
