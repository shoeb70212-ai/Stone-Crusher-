{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "regions": ["bom1"],
  "functions": {
    "api/data.ts": {
      "maxDuration": 30
    },
    "api/admin-users.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/data" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
